{
  "name": "@echomirror/react",
  "version": "0.1.0",
  "description": "EchoMirror SDK React bindings",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "keywords": [
    "echomirror",
    "react",
    "wellness"
  ],
  "license": "MIT",
  "dependencies": {
    "@echomirror/core": "*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "*",
    "vitest": "*",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0"
  }
}
