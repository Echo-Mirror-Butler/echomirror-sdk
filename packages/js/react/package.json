{
  "name": "@echomirror/react",
  "version": "0.1.0",
  "description": "EchoMirror SDK — React provider, hooks, and context for mood, stellar, and social features",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "keywords": [
    "echomirror",
    "react",
    "hooks",
    "sdk"
  ],
  "license": "MIT",
  "dependencies": {
    "@echomirror/core": "*"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "typescript": "*",
    "vitest": "*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0"
  },
  "type": "module"
}
