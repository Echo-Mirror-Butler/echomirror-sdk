{
  "name": "@echomirror/mood",
  "version": "0.1.0",
  "description": "EchoMirror SDK mood — mood logging, streaks, and AI reflections",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "keywords": ["echomirror", "wellness", "sdk", "mood"],
  "license": "MIT",
  "dependencies": {
    "@echomirror/core": "*"
  },
  "devDependencies": {
    "typescript": "*",
    "vitest": "*"
  }
}
