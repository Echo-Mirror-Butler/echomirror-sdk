{
  "name": "@echomirror/mood",
  "version": "0.1.0",
  "description": "EchoMirror SDK — mood logging, history, streaks, and AI reflections",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
