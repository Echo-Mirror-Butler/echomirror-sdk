# Node
node_modules/
package-lock.json
npm-debug.log*
*.tsbuildinfo

# Rust
/target/
Cargo.lock

# JS/TS build output
dist/
packages/js/*/dist/
packages/js/*/src/*.js
packages/js/*/src/*.d.ts
!packages/js/*/src/*.test.js

# Flutter/Dart
packages/flutter/.dart_tool/
